    {
      "parameters": {
        "jsCode": "// Get all incoming items\nconst items = $input.all();\nconst cleaned = [];\n\nfor (const item of items) {\n  // Use bracket notation to access the specific key name from the AI node\n  const jsonString = item.json[\"output[0].content[0].text\"];\n\n  if (!jsonString) continue;\n\n  try {\n    // 1. Clean the string in case the AI added Markdown code fences (```json ... ```)\n    const rawJson = jsonString.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n    \n    const parsedArray = JSON.parse(rawJson);\n\n    // Ensure we are dealing with an array\n    const dataToProcess = Array.isArray(parsedArray) ? parsedArray : [parsedArray];\n\n    for (const entry of dataToProcess) {\n      cleaned.push({\n        json: {\n          company_name: entry.legal_name || \"\",\n          brand_name: entry.brand_name || \"\",\n          funding_amount: entry.funding_amount || \"\",\n          currency: entry.currency || \"\",\n          funding_round: entry.funding_round || \"\",\n          investors: Array.isArray(entry.investors) ? entry.investors : [],\n          cin_number: entry.cin_number || \"Not Found\",\n          context_summary: entry.context_summary || \"No summary provided.\"\n        }\n      });\n    }\n  } catch (error) {\n    // Log the error to the console for debugging\n  }\n}\nreturn cleaned;"
      },
